<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.project.pms.mapper.AnnouncementCategoryMapper">
    <select id="selectAnnouncementCategoryInfoList" resultType="com.project.pms.entity.po.AnnouncementCategory">
        SELECT * FROM announcement_category
        <where>
            <if test="query.id!= null">
                AND id = #{query.id}
            </if>
            <if test="query.isActive!= null">
                AND is_active = #{isActive}
            </if>

            <if test="query.name!= null and query.name!= ''">
                AND name LIKE CONCAT('%', #{query.name}, '%')
            </if>
            <if test="query.colorType!= null and query.colorType!= ''">
                AND color_type LIKE CONCAT('%', #{query.colorType}, '%')
            </if>

            <!-- 创建时间范围查询 -->
            <if test="query.createTimeStart != null">
                AND create_time >= #{query.createTimeStart}
            </if>
            <if test="query.createTimeEnd != null">
                AND create_time &lt;= #{query.createTimeEnd}
            </if>

            <!-- 更新时间范围查询 -->
            <if test="query.updateTimeStart != null">
                AND update_time >= #{query.updateTimeStart}
            </if>
            <if test="query.updateTimeEnd != null">
                AND update_time &lt;= #{query.updateTimeEnd}
            </if>
        </where>

        <choose>
            <when test="query.orderByClause!= null and query.orderByClause!= ''">
                ORDER BY ${query.orderByClause}
            </when>
            <otherwise>
                ORDER BY id
                <if test="query.isAsc">ASC</if>
                <if test="!query.isAsc">DESC</if>
            </otherwise>
        </choose>
    </select>
</mapper>
